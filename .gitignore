# Dependencies
node_modules/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.suo
*.sln

# Secrets
*.env
.env*

# Large binaries
cloudflared.exe
*.exe

# Render / deployment artifacts
.render/

# Cloudflared tunnel logs
cf_*.log

# Excel data cache / backups (re-downloaded or re-synced at runtime)
backend/*.xlsx
backend/*.xlsx.download
backend/*.stale*.bak

# SQLite runtime DB
backend/logs.db
*.db
*.db-shm
*.db-wal

# Runtime follow-up store (created on first write)
backend/followup_data.json

# Runtime patient overrides store (app-side edits/delivery assignments)
backend/patient_overrides.json

# jsonStore crash-safety artifacts (backups, temp writes, quarantined files)
backend/*.json.bak
backend/*.json.tmp
backend/*.json.corrupt-*
